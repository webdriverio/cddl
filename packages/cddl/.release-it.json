{
  "plugins": {
    "@release-it/bumper": {
      "out": [
        "package.json"
      ]
    }
  },
  "git": {
    "requireCleanWorkingDir": false,
    "addUntrackedFiles": true,
    "tagName": "cddl-v${version}",
    "commitMessage": "chore(cddl): release v${version}",
    "changelog": "git log --pretty=format:\"* %s (%h)\" [REV_RANGE] -- . ../../examples ../../tsconfig.json"
  }
}
