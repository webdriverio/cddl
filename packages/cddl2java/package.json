  },
  "scripts": {
    "release": "release-it --github.release",
    "release:ci": "pnpm release --ci --npm.skipChecks"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.35",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
