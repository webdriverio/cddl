    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "camelcase": "^9.0.0",
    "@wdio/cddl": "workspace:*",
    "recast": "^0.23.11",
    "yargs": "^18.0.0"
  }
}
