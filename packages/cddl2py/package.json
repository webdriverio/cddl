{
  "name": "cddl2py",
  "version": "0.2.0",
  "description": "A Node.js package that can generate Python type definitions (with optional Pydantic support) based on a CDDL file",
  "author": "Christian Bromann <mail@bromann.dev>",
  "license": "MIT",
  "homepage": "https://github.com/webdriverio/cddl/blob/main/packages/cddl2py/README.md",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/webdriverio/cddl.git"
  },
  "keywords": [
    "cddl",
    "python",
    "pydantic",
    "dataclasses"
  ],
  "bugs": {
    "url": "https://github.com/webdriverio/cddl/issues"
  },
  "files": [
    "build",
    "bin"
  ],
  "type": "module",
  "exports": "./build/index.js",
  "types": "./build/index.d.ts",
  "bin": {
    "cddl2py": "./bin/cddl2py.js"
  },
  "scripts": {
    "release": "release-it --config .release-it.ts --VV",
    "release:ci": "pnpm release --ci --npm.skipChecks"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.35",
    "@types/node": "^25.5.0"
  },
  "dependencies": {
    "cddl": "workspace:*",
    "yargs": "^18.0.0"
  }
}
